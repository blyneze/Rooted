generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String             @id @default(uuid())
  clerkId         String             @unique
  email           String?
  firstName       String?
  lastName        String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  bibleBookmarks  BibleBookmark[]
  bibleHighlights BibleHighlight[]
  bibleNotes      BibleNote[]
  downloads       Download[]
  progress        PlaybackProgress[]
  playbackRecords PlaybackRecord[]
  playlists       Playlist[]
  savedItems      SavedItem[]
  preferences     UserPreference?
}

model Series {
  id          String          @id @default(uuid())
  title       String
  description String?
  coverUrl    String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  messages    SeriesMessage[]
}

model AudioMessage {
  id              String                @id @default(uuid())
  title           String
  duration        Int
  audioUrl        String
  coverUrl        String
  speakerName     String
  releaseDate     DateTime
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  downloads       Download[]
  featuredSection FeaturedSectionItem[]
  topics          MessageTopic[]
  progressRecords PlaybackProgress[]
  plays           PlaybackRecord[]
  playlistItems   PlaylistItem[]
  savedBy         SavedItem[]
  seriesItems     SeriesMessage[]
}

model VideoMessage {
  id              String                @id @default(uuid())
  title           String
  description     String?
  duration        Int
  videoUrl        String?
  coverUrl        String?
  speakerName     String
  releaseDate     DateTime
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  youtubeId       String
  downloads       Download[]
  featuredSection FeaturedSectionItem[]
  topics          MessageTopic[]
  progressRecords PlaybackProgress[]
  plays           PlaybackRecord[]
  playlistItems   PlaylistItem[]
  savedBy         SavedItem[]
  seriesItems     SeriesMessage[]
}

model PlaybackRecord {
  id        String        @id @default(uuid())
  userId    String
  audioId   String?
  videoId   String?
  progress  Float
  updatedAt DateTime      @updatedAt
  audio     AudioMessage? @relation(fields: [audioId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [clerkId], onDelete: Cascade)
  video     VideoMessage? @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, audioId])
  @@unique([userId, videoId])
}

model SeriesMessage {
  id         String        @id @default(uuid())
  seriesId   String
  audioId    String?
  videoId    String?
  orderIndex Int
  audio      AudioMessage? @relation(fields: [audioId], references: [id], onDelete: Cascade)
  series     Series        @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  video      VideoMessage? @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([seriesId, audioId])
  @@unique([seriesId, videoId])
}

model Book {
  id              String                @id @default(uuid())
  title           String
  author          String
  description     String?
  coverUrl        String
  epubUrl         String?
  audioUrl        String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  downloads       Download[]
  featuredSection FeaturedSectionItem[]
  savedBy         SavedItem[]
}

model FeaturedSection {
  id         String                @id @default(uuid())
  title      String
  orderIndex Int                   @default(0)
  items      FeaturedSectionItem[]
}

model FeaturedSectionItem {
  id         String          @id @default(uuid())
  sectionId  String
  audioId    String?
  videoId    String?
  bookId     String?
  orderIndex Int
  audio      AudioMessage?   @relation(fields: [audioId], references: [id], onDelete: Cascade)
  book       Book?           @relation(fields: [bookId], references: [id], onDelete: Cascade)
  section    FeaturedSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  video      VideoMessage?   @relation(fields: [videoId], references: [id], onDelete: Cascade)
}

model Topic {
  id       String         @id @default(uuid())
  name     String         @unique
  messages MessageTopic[]
}

model MessageTopic {
  id      String        @id @default(uuid())
  audioId String?
  videoId String?
  topicId String
  audio   AudioMessage? @relation(fields: [audioId], references: [id], onDelete: Cascade)
  topic   Topic         @relation(fields: [topicId], references: [id], onDelete: Cascade)
  video   VideoMessage? @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([audioId, topicId])
  @@unique([videoId, topicId])
}

model Playlist {
  id          String         @id @default(uuid())
  userId      String
  name        String
  description String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [clerkId], onDelete: Cascade)
  items       PlaylistItem[]
}

model PlaylistItem {
  id         String        @id @default(uuid())
  playlistId String
  audioId    String?
  videoId    String?
  addedAt    DateTime      @default(now())
  orderIndex Int
  audio      AudioMessage? @relation(fields: [audioId], references: [id], onDelete: Cascade)
  playlist   Playlist      @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  video      VideoMessage? @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([playlistId, audioId])
  @@unique([playlistId, videoId])
}

model SavedItem {
  id      String        @id @default(uuid())
  userId  String
  audioId String?
  videoId String?
  bookId  String?
  savedAt DateTime      @default(now())
  audio   AudioMessage? @relation(fields: [audioId], references: [id], onDelete: Cascade)
  book    Book?         @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [clerkId], onDelete: Cascade)
  video   VideoMessage? @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, audioId])
  @@unique([userId, videoId])
  @@unique([userId, bookId])
}

model PlaybackProgress {
  id          String        @id @default(uuid())
  userId      String
  audioId     String?
  videoId     String?
  progress    Float
  position    Int
  isCompleted Boolean       @default(false)
  updatedAt   DateTime      @updatedAt
  audio       AudioMessage? @relation(fields: [audioId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [clerkId], onDelete: Cascade)
  video       VideoMessage? @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, audioId])
  @@unique([userId, videoId])
}

model Download {
  id           String        @id @default(uuid())
  userId       String
  audioId      String?
  videoId      String?
  bookId       String?
  mediaType    String        @default("audio")
  localPath    String?
  downloadedAt DateTime      @default(now())
  audio        AudioMessage? @relation(fields: [audioId], references: [id], onDelete: Cascade)
  book         Book?         @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [clerkId], onDelete: Cascade)
  video        VideoMessage? @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, audioId])
  @@unique([userId, videoId])
  @@unique([userId, bookId])
}

model UserPreference {
  id                 String  @id @default(uuid())
  userId             String  @unique
  pushNotifications  Boolean @default(true)
  emailNotifications Boolean @default(true)
  autoDownloadQueue  Boolean @default(false)
  user               User    @relation(fields: [userId], references: [clerkId], onDelete: Cascade)
}

model BibleNote {
  id        String   @id @default(uuid())
  userId    String
  book      String
  chapter   Int
  verse     Int?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [clerkId], onDelete: Cascade)
}

model BibleHighlight {
  id        String   @id @default(uuid())
  userId    String
  book      String
  chapter   Int
  verse     Int
  colorHex  String   @default("#FFE082")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [clerkId], onDelete: Cascade)

  @@unique([userId, book, chapter, verse])
}

model BibleBookmark {
  id        String   @id @default(uuid())
  userId    String
  book      String
  chapter   Int
  verse     Int?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [clerkId], onDelete: Cascade)

  @@unique([userId, book, chapter, verse])
}
